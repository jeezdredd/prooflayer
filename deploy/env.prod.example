# ProofLayer production env - copy to /srv/prooflayer/shared/.env on the server
# chmod 600 after editing. NEVER commit real values.

# ===== Django =====
SECRET_KEY=replace-with-output-of-`python -c "import secrets; print(secrets.token_urlsafe(64))"`
ALLOWED_HOSTS=prooflayer.cloud,api.prooflayer.cloud,flower.prooflayer.cloud
CORS_ALLOWED_ORIGINS=https://prooflayer.cloud
DJANGO_SETTINGS_MODULE=config.settings.prod

# ===== Postgres (inside compose network) =====
POSTGRES_PASSWORD=replace-with-strong-random

# ===== MinIO (S3-compat for media files) =====
MINIO_ROOT_USER=prooflayer
MINIO_ROOT_PASSWORD=replace-with-strong-random
AWS_STORAGE_BUCKET_NAME=prooflayer-media

# ===== Ollama =====
# 16GB RAM + RX 6700S GPU lifts the 12GB dev ceiling.
# Can run qwen2.5vl:7b comfortably; keep MAX_LOADED_MODELS=2 so text+vision coexist.
OLLAMA_IMAGE=ollama/ollama:rocm
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_VISION_MODEL=qwen2.5vl:3b
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_KEEP_ALIVE=10m

# ===== Frontend build-time =====
VITE_API_URL=https://api.prooflayer.cloud/api/v1

# ===== Auth cookies (refresh token httpOnly) =====
# Domain left empty = host-only cookie. Set to .prooflayer.cloud only if you
# need cross-subdomain refresh (we don't; api.prooflayer.cloud serves /auth/).
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=Lax

# ===== Email (Gmail SMTP) =====
# Use a Gmail App Password (https://myaccount.google.com/apppasswords),
# not the account password. EMAIL_HOST_USER = full address.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=ProofLayer <noreply@prooflayer.cloud>
FRONTEND_URL=https://prooflayer.cloud

# ===== Discord visit notifications (optional) =====
# Create webhook in Discord server settings -> Integrations -> Webhooks.
# Empty = feature off. IP + ip-api geo lookup posted to channel via embed.
DISCORD_WEBHOOK_URL=

# ===== HuggingFace (optional, for gated models) =====
HF_TOKEN=

# ===== Sentry (optional) =====
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
