# ── Local dev ─────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-production

POSTGRES_DB=prooflayer
POSTGRES_USER=prooflayer
POSTGRES_PASSWORD=prooflayer_dev
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://prooflayer:prooflayer_dev@db:5432/prooflayer

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

VITE_API_URL=http://localhost:8000/api/v1

# ── AI models ─────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_VISION_MODEL=llava:7b

# ── Training ──────────────────────────────────────────────
HF_TOKEN=

# ── Monitoring ────────────────────────────────────────────
SENTRY_DSN=

# ── Production / Railway (set these in Railway dashboard) ─
# DJANGO_SETTINGS_MODULE=config.settings.prod
# SECRET_KEY=<strong-random-key>
# DATABASE_URL=<railway-postgres-url>
# REDIS_URL=<railway-redis-url>
# CELERY_BROKER_URL=<railway-redis-url>
# ALLOWED_HOSTS=<your-railway-domain>.up.railway.app
# CORS_ALLOWED_ORIGINS=https://<your-frontend-domain>

# ── S3 media storage (production) ─────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=
